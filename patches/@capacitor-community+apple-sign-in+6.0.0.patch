+extension SignInWithApple: ASAuthorizationControllerPresentationContextProviding {
+    public func presentationAnchor(for controller: ASAuthorizationController) -> ASPresentationAnchor {
+        // Anchor MUST be a real attached window. Returning an empty ASPresentationAnchor()
+        // or a window not attached to a foreground-active UIWindowScene causes
+        // ASAuthorizationError.unknown (code 1000) on iPad, especially under
+        // iPadOS 17+ Stage Manager / Split View. We prefer in this order:
+        //   1. The foreground-active scene's key window
+        //   2. The foreground-active scene's first window
+        //   3. The bridge view controller's window (legacy fallback)
+        //   4. Any window from any window scene (last resort)
+        let activeScenes = UIApplication.shared.connectedScenes
+            .compactMap { $0 as? UIWindowScene }
+            .filter { $0.activationState == .foregroundActive }
+        if let keyWindow = activeScenes.flatMap({ $0.windows }).first(where: { $0.isKeyWindow }) {
+            return keyWindow
+        }
+        if let anyActiveWindow = activeScenes.flatMap({ $0.windows }).first {
+            return anyActiveWindow
+        }
+        if let bridgeWindow = self.bridge?.viewController?.view.window {
+            return bridgeWindow
+        }
+        if let anyWindow = UIApplication.shared.connectedScenes
+            .compactMap({ $0 as? UIWindowScene })
+            .flatMap({ $0.windows })
+            .first {
+            return anyWindow
+        }
+        // Absolute last resort. ASPresentationAnchor() is invalid on its own
+        // but at least the call stack is in the logs by this point.
+        return ASPresentationAnchor()
+    }
